{
    "subFolders": 
    {
        "nes":
        {   
            "fileExtension": ".nes",
            "application": "flatpak",
            "arguments": 
            [
                "run",
                "NESBOX",
                "{filePath}"
            ]
        },
        "snes":
        {
            "fileExtension": ".sfc",
            "application": "flatpak",
            "arguments": 
            [
                "run",
                "snes9x",
                "{filePath}"
            ]
        },
        "gc":
        {
            "fileExtension": ".iso",
            "application": "flatpak",
            "arguments":
            [
                "run",
                "dolphin",
                "--exec={filePath}"
            ]
        }
    }
}